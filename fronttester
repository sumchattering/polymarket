#!/bin/bash
# fronttester — manage Polymarket front-testing strategies
#
# Usage:
#   fronttester start <strategy> [coin]   Start a strategy (fresh $100)
#   fronttester stop <strategy>           Stop a running strategy
#   fronttester restart <strategy> [coin] Stop + start fresh
#   fronttester follow <strategy>         Tail live logs
#   fronttester status [strategy]         Show balance & stats
#   fronttester list                      List all strategies
#
# Coins: dogecoin, xrp, ethereum, solana, bitcoin, bnb

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BACKTEST_DIR="$SCRIPT_DIR/backtesting"
VENV="$BACKTEST_DIR/.venv/bin/python"
PLIST_DIR="$HOME/Library/LaunchAgents"
PLIST_PREFIX="com.polymarket.fronttester"

strategy_plist() { echo "$PLIST_DIR/${PLIST_PREFIX}.${1}.plist"; }
strategy_db()    { echo "$BACKTEST_DIR/db_${1}.db"; }
strategy_log()   { echo "$BACKTEST_DIR/logs_${1}.log"; }

is_running() {
    launchctl list 2>/dev/null | grep -q "${PLIST_PREFIX}.${1}"
}

cmd_start() {
    local strategy="$1"
    local coin="${2:-dogecoin}"
    if [ -z "$strategy" ]; then
        echo "Usage: fronttester start <strategy> [coin]"
        echo ""
        echo "Available strategies:"
        for f in "$BACKTEST_DIR/strategies/"*.py; do
            [ -f "$f" ] || continue
            local name=$(basename "$f" .py)
            [ "$name" = "__init__" ] && continue
            echo "  $name"
        done
        echo ""
        echo "Coins: dogecoin (default), xrp, ethereum, solana, bitcoin, bnb"
        return 1
    fi

    if [ ! -f "$BACKTEST_DIR/strategies/${strategy}.py" ]; then
        echo "Strategy not found: ${strategy}"
        echo "Run 'fronttester list' to see available strategies."
        return 1
    fi

    # Use strategy_coin as the service name for per-coin isolation
    local service_name="${strategy}_${coin}"

    if is_running "$service_name"; then
        echo "Strategy '$strategy' on $coin is already running."
        echo ""
        echo "  fronttester follow $service_name    — view live logs"
        echo "  fronttester status $service_name    — check stats"
        echo "  fronttester restart $strategy $coin — restart fresh"
        echo "  fronttester stop $service_name      — stop it"
        return 0
    fi

    local db_path=$(strategy_db "$service_name")
    local log_path=$(strategy_log "$service_name")
    local plist=$(strategy_plist "$service_name")

    # Fresh start: clear logs and DB
    > "$log_path"
    rm -f "$db_path"

    mkdir -p "$PLIST_DIR"

    cat > "$plist" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${PLIST_PREFIX}.${service_name}</string>
    <key>ProgramArguments</key>
    <array>
        <string>${VENV}</string>
        <string>${BACKTEST_DIR}/run_live.py</string>
        <string>--strategy</string>
        <string>${strategy}</string>
        <string>--coin</string>
        <string>${coin}</string>
        <string>--reset</string>
        <string>--balance</string>
        <string>100</string>
        <string>--db</string>
        <string>${db_path}</string>
        <string>--log</string>
        <string>${log_path}</string>
    </array>
    <key>WorkingDirectory</key>
    <string>${SCRIPT_DIR}</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>${log_path}</string>
    <key>StandardErrorPath</key>
    <string>${log_path}</string>
</dict>
</plist>
EOF

    launchctl load "$plist"
    echo "Started strategy '$strategy' on $coin"
    echo ""
    echo "  Balance:  \$100.00"
    echo "  Coin:     $coin"
    echo "  DB:       $db_path"
    echo "  Logs:     $log_path"
    echo ""
    echo "  fronttester follow $service_name    — view live logs"
    echo "  fronttester status $service_name    — check stats"
    echo "  fronttester stop $service_name      — stop it"
}

cmd_stop() {
    local strategy="$1"
    if [ -z "$strategy" ]; then
        echo "Usage: fronttester stop <strategy>"
        return 1
    fi

    local plist=$(strategy_plist "$strategy")

    if ! is_running "$strategy"; then
        echo "Strategy '$strategy' is not running."
        return 0
    fi

    launchctl unload "$plist" 2>/dev/null
    rm -f "$plist"
    echo "Stopped strategy '$strategy'"
}

cmd_restart() {
    local strategy="$1"
    local coin="${2:-dogecoin}"
    local service_name="${strategy}_${coin}"
    if [ -z "$strategy" ]; then
        echo "Usage: fronttester restart <strategy> [coin]"
        return 1
    fi

    cmd_stop "$service_name" 2>/dev/null || true
    sleep 1
    cmd_start "$strategy" "$coin"
}

cmd_follow() {
    local strategy="$1"
    if [ -z "$strategy" ]; then
        echo "Usage: fronttester follow <strategy>"
        return 1
    fi

    local log_path=$(strategy_log "$strategy")
    if [ ! -f "$log_path" ]; then
        echo "No logs found for '$strategy'. Has it been started?"
        return 1
    fi

    tail -f "$log_path"
}

cmd_status() {
    local strategy="$1"

    if [ -n "$strategy" ]; then
        local db_path=$(strategy_db "$strategy")
        local running="stopped"
        is_running "$strategy" && running="RUNNING"

        echo "Strategy: $strategy [$running]"
        echo ""
        if [ -f "$db_path" ]; then
            "$VENV" -c "
import sys; sys.path.insert(0, '$BACKTEST_DIR')
import db
stats = db.get_stats(db_path='$db_path')
print(f'  Balance:     \${stats[\"balance\"]:.2f}')
print(f'  Trades:      {stats[\"total_trades\"]}')
print(f'  Wins:        {stats[\"wins\"]}')
print(f'  Losses:      {stats[\"losses\"]}')
print(f'  Win Rate:    {stats[\"win_rate\"]:.1f}%')
print(f'  PnL:        \${stats[\"total_pnl\"]:+.2f}')
print(f'  Fees:       \${stats[\"total_fees\"]:.2f}')
print(f'  Open Bets:   {stats[\"open_positions\"]}')
" 2>/dev/null || echo "  No data yet"
        else
            echo "  No data yet. Start with: fronttester start $strategy"
        fi
    else
        echo "=== Front-tester Status ==="
        echo ""
        local found=false
        # Find all service DBs (db_*.db files)
        for dbfile in "$BACKTEST_DIR"/db_*.db; do
            [ -f "$dbfile" ] || continue
            local basename=$(basename "$dbfile" .db)
            local name="${basename#db_}"  # strip "db_" prefix
            local running="stopped"
            is_running "$name" && running="RUNNING"

            found=true
            "$VENV" -c "
import sys; sys.path.insert(0, '$BACKTEST_DIR')
import db
from datetime import datetime, timezone
conn = db.get_db('$dbfile')
acct = conn.execute('SELECT created_at FROM account WHERE id=1').fetchone()
conn.close()
stats = db.get_stats(db_path='$dbfile')
wr = f\"{stats['win_rate']:.0f}%\" if stats['total_trades'] > 0 else '-'
uptime = ''
if acct and acct['created_at']:
    started = datetime.fromisoformat(acct['created_at'])
    delta = datetime.now(timezone.utc) - started
    days = delta.days
    hours = delta.seconds // 3600
    if days > 0:
        uptime = f'{days}d {hours}h'
    else:
        uptime = f'{hours}h'
print(f'  {\"$name\":<30s} [{\"$running\":>7s}]  \${stats[\"balance\"]:>8.2f}  W/L: {stats[\"wins\"]}/{stats[\"losses\"]}  WR: {wr}  PnL: \${stats[\"total_pnl\"]:+.2f}  ({uptime})')
" 2>/dev/null
        done
        if [ "$found" = false ]; then
            echo "  No strategies have run yet."
            echo "  Start one with: fronttester start <strategy> [coin]"
        fi
    fi
}

cmd_list() {
    echo "Available strategies:"
    echo ""
    for f in "$BACKTEST_DIR/strategies/"*.py; do
        [ -f "$f" ] || continue
        local name=$(basename "$f" .py)
        [ "$name" = "__init__" ] && continue
        local status="stopped"
        is_running "$name" && status="RUNNING"
        printf "  %-25s [%s]\n" "$name" "$status"
    done
}

case "${1:-}" in
    start)   cmd_start "$2" "$3" ;;
    stop)    cmd_stop "$2" ;;
    restart) cmd_restart "$2" "$3" ;;
    follow)  cmd_follow "$2" ;;
    status)  cmd_status "$2" ;;
    list)    cmd_list ;;
    *)
        echo "fronttester — manage Polymarket front-testing strategies"
        echo ""
        echo "Usage:"
        echo "  fronttester start <strategy> [coin]   Start fresh (\$100 balance)"
        echo "  fronttester stop <service_name>       Stop a running strategy"
        echo "  fronttester restart <strategy> [coin]  Restart fresh"
        echo "  fronttester follow <service_name>     Tail live logs"
        echo "  fronttester status [service_name]     Show stats (all or one)"
        echo "  fronttester list                      List all strategies"
        echo ""
        echo "Coins: dogecoin (default), xrp, ethereum, solana, bitcoin, bnb"
        ;;
esac
