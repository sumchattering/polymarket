#!/bin/bash
# fronttester — manage Polymarket front-testing strategies
#
# Usage:
#   fronttester start <strategy> [coin]   Start a strategy (fresh $100)
#   fronttester stop <service_name>       Stop a running strategy
#   fronttester restart <strategy> [coin] Stop + start fresh
#   fronttester follow <service_name>     Tail live logs
#   fronttester status [service_name]     Show balance & stats
#   fronttester list                      List all strategies
#
# Coins: dogecoin, xrp, ethereum, solana, bitcoin, bnb

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BACKTEST_DIR="$SCRIPT_DIR/backtesting"
VENV="$BACKTEST_DIR/.venv/bin/python"
DATA_DIR="$HOME/.polymarket/data"
LOG_DIR="$HOME/.polymarket/logs"
PLIST_DIR="$HOME/Library/LaunchAgents"
PLIST_PREFIX="com.polymarket.fronttester"
MAX_RUNTIME_DAYS=8

mkdir -p "$DATA_DIR" "$LOG_DIR"

strategy_plist() { echo "$PLIST_DIR/${PLIST_PREFIX}.${1}.plist"; }
strategy_db()    { echo "$DATA_DIR/db_${1}.db"; }
strategy_log()   { echo "$LOG_DIR/logs_${1}.log"; }

is_running() {
    launchctl list 2>/dev/null | grep -q "${PLIST_PREFIX}.${1}"
}

# Parse service name into strategy + coin
# Service name format: {strategy}_{coin}
# Known coins are checked from the end
parse_service_name() {
    local name="$1"
    local coin="${name##*_}"
    local strategy="${name%_${coin}}"
    echo "$strategy" "$coin"
}

cmd_start() {
    local strategy="$1"
    local coin="${2:-dogecoin}"
    if [ -z "$strategy" ]; then
        echo "Usage: fronttester start <strategy> [coin]"
        echo ""
        echo "Available strategies:"
        for f in "$SCRIPT_DIR/strategies/"*.py; do
            [ -f "$f" ] || continue
            local name=$(basename "$f" .py)
            [ "$name" = "__init__" ] && continue
            echo "  $name"
        done
        echo ""
        echo "Coins: dogecoin (default), xrp, ethereum, solana, bitcoin, bnb"
        return 1
    fi

    if [ ! -f "$SCRIPT_DIR/strategies/${strategy}.py" ]; then
        echo "Strategy not found: ${strategy}"
        echo "Run 'fronttester list' to see available strategies."
        return 1
    fi

    local service_name="${strategy}_${coin}"

    if is_running "$service_name"; then
        echo "Strategy '$strategy' on $coin is already running."
        echo ""
        echo "  fronttester follow $service_name    — view live logs"
        echo "  fronttester status $service_name    — check stats"
        echo "  fronttester stop $service_name      — stop it"
        return 0
    fi

    local db_path=$(strategy_db "$service_name")
    local log_path=$(strategy_log "$service_name")
    local plist=$(strategy_plist "$service_name")

    # Fresh start: clear logs and DB
    > "$log_path"
    rm -f "$db_path"

    mkdir -p "$PLIST_DIR"

    cat > "$plist" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${PLIST_PREFIX}.${service_name}</string>
    <key>ProgramArguments</key>
    <array>
        <string>${VENV}</string>
        <string>${BACKTEST_DIR}/run_live.py</string>
        <string>--strategy</string>
        <string>${strategy}</string>
        <string>--coin</string>
        <string>${coin}</string>
        <string>--reset</string>
        <string>--balance</string>
        <string>100</string>
        <string>--db</string>
        <string>${db_path}</string>
        <string>--log</string>
        <string>${log_path}</string>
    </array>
    <key>WorkingDirectory</key>
    <string>${SCRIPT_DIR}</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>${log_path}</string>
    <key>StandardErrorPath</key>
    <string>${log_path}</string>
</dict>
</plist>
EOF

    launchctl load "$plist"
    echo "Started strategy '$strategy' on $coin"
    echo ""
    echo "  Balance:  \$100.00"
    echo "  Coin:     $coin"
    echo "  DB:       $db_path"
    echo "  Logs:     $log_path"
    echo ""
    echo "  fronttester follow $service_name    — view live logs"
    echo "  fronttester status $service_name    — check stats"
    echo "  fronttester stop $service_name      — stop it"
}

cmd_stop() {
    local strategy="$1"
    if [ -z "$strategy" ]; then
        echo "Usage: fronttester stop <strategy>"
        return 1
    fi

    local plist=$(strategy_plist "$strategy")

    if ! is_running "$strategy"; then
        echo "Strategy '$strategy' is not running."
        return 0
    fi

    launchctl unload "$plist" 2>/dev/null
    rm -f "$plist"
    echo "Stopped strategy '$strategy'"
}

cmd_restart() {
    local strategy="$1"
    local coin="${2:-dogecoin}"
    local service_name="${strategy}_${coin}"
    if [ -z "$strategy" ]; then
        echo "Usage: fronttester restart <strategy> [coin]"
        return 1
    fi

    cmd_stop "$service_name" 2>/dev/null || true
    sleep 1
    cmd_start "$strategy" "$coin"
}

cmd_reload() {
    local name="$1"
    if [ -z "$name" ]; then
        echo "Usage: fronttester reload <service_name>    (reload one)"
        echo "       fronttester reload all               (reload all running)"
        return 1
    fi

    if [ "$name" = "all" ]; then
        local count=0
        for dbfile in "$DATA_DIR"/db_*.db; do
            [ -f "$dbfile" ] || continue
            local basename=$(basename "$dbfile" .db)
            local svc="${basename#db_}"
            if is_running "$svc"; then
                cmd_reload "$svc"
                count=$((count + 1))
            fi
        done
        echo "Reloaded $count services"
        return 0
    fi

    local plist=$(strategy_plist "$name")

    if ! is_running "$name"; then
        echo "Strategy '$name' is not running."
        return 1
    fi

    # Parse strategy and coin from service name
    local parsed=($(parse_service_name "$name"))
    local strategy="${parsed[0]}"
    local coin="${parsed[1]}"

    # Validate strategy file exists
    if [ ! -f "$SCRIPT_DIR/strategies/${strategy}.py" ]; then
        echo "Error: strategy file '${strategy}.py' not found for service '$name'"
        return 1
    fi

    local db_path=$(strategy_db "$name")
    local log_path=$(strategy_log "$name")

    # Rewrite plist WITHOUT --reset to preserve DB
    cat > "$plist" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${PLIST_PREFIX}.${name}</string>
    <key>ProgramArguments</key>
    <array>
        <string>${VENV}</string>
        <string>${BACKTEST_DIR}/run_live.py</string>
        <string>--strategy</string>
        <string>${strategy}</string>
        <string>--coin</string>
        <string>${coin}</string>
        <string>--db</string>
        <string>${db_path}</string>
        <string>--log</string>
        <string>${log_path}</string>
    </array>
    <key>WorkingDirectory</key>
    <string>${SCRIPT_DIR}</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>${log_path}</string>
    <key>StandardErrorPath</key>
    <string>${log_path}</string>
</dict>
</plist>
EOF

    launchctl unload "$plist" 2>/dev/null
    sleep 2
    launchctl load "$plist"
    echo "Reloaded '$name' (DB and logs preserved)"
}

cmd_follow() {
    local strategy="$1"
    if [ -z "$strategy" ]; then
        echo "Usage: fronttester follow <strategy>"
        return 1
    fi

    local log_path=$(strategy_log "$strategy")
    if [ ! -f "$log_path" ]; then
        echo "No logs found for '$strategy'. Has it been started?"
        return 1
    fi

    tail -f "$log_path"
}

cmd_status() {
    local strategy="$1"

    if [ -n "$strategy" ]; then
        local db_path=$(strategy_db "$strategy")
        local running="stopped"
        is_running "$strategy" && running="RUNNING"

        echo "Strategy: $strategy [$running]"
        echo ""
        if [ -f "$db_path" ]; then
            "$VENV" -c "
import sys; sys.path.insert(0, '$BACKTEST_DIR')
import db
stats = db.get_stats(db_path='$db_path')
print(f'  Balance:     \${stats[\"balance\"]:.2f}')
print(f'  Trades:      {stats[\"total_trades\"]}')
print(f'  Wins:        {stats[\"wins\"]}')
print(f'  Losses:      {stats[\"losses\"]}')
print(f'  Win Rate:    {stats[\"win_rate\"]:.1f}%')
print(f'  PnL:        \${stats[\"total_pnl\"]:+.2f}')
print(f'  Fees:       \${stats[\"total_fees\"]:.2f}')
print(f'  Open Bets:   {stats[\"open_positions\"]}')
" 2>/dev/null || echo "  No data yet"
        else
            echo "  No data yet. Start with: fronttester start $strategy"
        fi
    else
        echo "=== Front-tester Status ==="
        echo "  Each strategy runs for a maximum of $MAX_RUNTIME_DAYS days."
        echo "  Position sizing: 2% (<2x balance) -> 3% (<4x) -> 4% (4x+)"
        echo ""

        local expected_file="$DATA_DIR/expected_wr.json"
        local has_expected=false
        [ -f "$expected_file" ] && has_expected=true

        printf "  %-34s %10s  %9s  %5s  %9s  %9s  %10s  %7s  %6s  %6s\n" \
            "Strategy" "Status" "Balance" "Tots" "WR (exp)" "PnL" "Tr/d (exp)" "Uptime" "LT" "LH"
        printf "  %s\n" "$(printf '%0.s-' {1..123})"

        local found=false
        # Find all service DBs (db_*.db files)
        for dbfile in "$DATA_DIR"/db_*.db; do
            [ -f "$dbfile" ] || continue
            local basename=$(basename "$dbfile" .db)
            local name="${basename#db_}"  # strip "db_" prefix
            local running="stopped"
            is_running "$name" && running="RUNNING"

            # Check for finished status in DB
            if [ "$running" = "stopped" ]; then
                local finished=$("$VENV" -c "
import sqlite3
conn = sqlite3.connect('$dbfile')
conn.row_factory = sqlite3.Row
try:
    r = conn.execute('SELECT status FROM account WHERE id=1').fetchone()
    print(r['status'] if r and r['status'] else '')
except: pass
conn.close()
" 2>/dev/null)
                [ "$finished" = "finished" ] && running="FINISHED"
            fi

            found=true
            "$VENV" -c "
import sys, json; sys.path.insert(0, '$BACKTEST_DIR')
import db
from datetime import datetime, timezone
conn = db.get_db('$dbfile')
try:
    acct = conn.execute('SELECT created_at, last_heartbeat FROM account WHERE id=1').fetchone()
except Exception:
    acct = conn.execute('SELECT created_at FROM account WHERE id=1').fetchone()
conn.close()
stats = db.get_stats(db_path='$dbfile')
has_trades = stats['total_trades'] > 0
wr = f\"{stats['win_rate']:.0f}%\" if has_trades else 'n/a'

# Compute uptime and trades/day
uptime = ''
tpd = 'n/a'
if acct and acct['created_at']:
    hb = acct['last_heartbeat'] if 'last_heartbeat' in acct.keys() else None
    if hb:
        started = datetime.fromisoformat(acct['created_at'])
        if '$running' != 'RUNNING':
            end = datetime.fromisoformat(hb)
        else:
            end = datetime.now(timezone.utc)
        delta = end - started
        d = delta.days
        h = delta.seconds // 3600
        if d > 0:
            uptime = f'{d}d {h}h'
        else:
            uptime = f'{h}h'
        if has_trades:
            conn2 = db.get_db('$dbfile')
            first = conn2.execute('SELECT placed_at FROM trades ORDER BY placed_at ASC LIMIT 1').fetchone()
            last_trade_row = conn2.execute('SELECT placed_at FROM trades ORDER BY placed_at DESC LIMIT 1').fetchone()
            conn2.close()
            if first and last_trade_row:
                t0 = datetime.fromisoformat(first['placed_at'])
                t1 = datetime.fromisoformat(last_trade_row['placed_at'])
                span = max((t1 - t0).total_seconds() / 86400, 0.01)
                tpd = f\"{stats['total_trades'] / span:.0f}\"

# Load expected stats
exp_wr = 'n/a'
exp_tpd = 'n/a'
if '$has_expected' == 'true':
    try:
        with open('$expected_file') as f:
            expected = json.load(f)
        e = expected.get('$name', {})
        if isinstance(e, dict):
            if e.get('wr'): exp_wr = f\"{e['wr']:.0f}%\"
            if e.get('trades_per_day'): exp_tpd = f\"{e['trades_per_day']:.0f}\"
    except Exception:
        pass

tots = f\"{stats['total_trades']}\" if has_trades else 'n/a'
bal = f\"\${stats['balance']:.2f}\"
pnl_val = stats['total_pnl']
pnl = f'+\${pnl_val:.2f}' if pnl_val >= 0 else f'-\${abs(pnl_val):.2f}'

# Last trade time
lt = 'n/a'
if has_trades:
    conn3 = db.get_db('$dbfile')
    lt_row = conn3.execute('SELECT placed_at FROM trades ORDER BY placed_at DESC LIMIT 1').fetchone()
    conn3.close()
    if lt_row:
        lt_dt = datetime.fromisoformat(lt_row['placed_at'])
        ago = (datetime.now(timezone.utc) - lt_dt).total_seconds()
        if ago < 3600:
            lt = f'{int(ago/60)}m'
        elif ago < 86400:
            lt = f'{int(ago/3600)}h'
        else:
            lt = f'{int(ago/86400)}d'

# Last heartbeat
lh = 'n/a'
if acct and acct['created_at']:
    hb_val = acct['last_heartbeat'] if 'last_heartbeat' in acct.keys() else None
    if hb_val:
        hb_dt = datetime.fromisoformat(hb_val)
        ago = (datetime.now(timezone.utc) - hb_dt).total_seconds()
        if ago < 3600:
            lh = f'{int(ago/60)}m'
        elif ago < 86400:
            lh = f'{int(ago/3600)}h'
        else:
            lh = f'{int(ago/86400)}d'

print(f'  {\"$name\":<34s} [{\"$running\":>8s}]  {bal:>9s}  {tots:>5s}  {wr:>4s} ({exp_wr:>3s})  {pnl:>9s}  {tpd:>3s} ({exp_tpd:>3s})  {uptime:>7s}  {lt:>5s}  {lh:>5s}')
" 2>/dev/null
        done
        if [ "$found" = false ]; then
            echo "  No strategies have run yet."
            echo "  Start one with: fronttester start <strategy> [coin]"
        fi
    fi
}

cmd_list() {
    echo "Available strategies:"
    echo ""
    for f in "$SCRIPT_DIR/strategies/"*.py; do
        [ -f "$f" ] || continue
        local name=$(basename "$f" .py)
        [ "$name" = "__init__" ] && continue
        local status="stopped"
        is_running "$name" && status="RUNNING"
        printf "  %-25s [%s]\n" "$name" "$status"
    done
}

case "${1:-}" in
    start)   cmd_start "$2" "$3" ;;
    stop)    cmd_stop "$2" ;;
    restart) cmd_restart "$2" "$3" ;;
    reload)  cmd_reload "$2" ;;
    follow)  cmd_follow "$2" ;;
    status)  cmd_status "$2" ;;
    list)    cmd_list ;;
    *)
        echo "fronttester — manage Polymarket front-testing strategies"
        echo ""
        echo "Usage:"
        echo "  fronttester start <strategy> [coin]   Start fresh (\$100 balance)"
        echo "  fronttester stop <service_name>       Stop a running strategy"
        echo "  fronttester restart <strategy> [coin]  Restart fresh (wipes DB)"
        echo "  fronttester reload <service_name|all>  Reload code (keeps DB/logs)"
        echo "  fronttester follow <service_name>     Tail live logs"
        echo "  fronttester status [service_name]     Show stats (all or one)"
        echo "  fronttester list                      List all strategies"
        echo ""
        echo "Coins: dogecoin (default), xrp, ethereum, solana, bitcoin, bnb"
        ;;
esac
